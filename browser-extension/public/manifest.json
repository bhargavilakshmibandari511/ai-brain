{
  "manifest_version": 3,
  "name": "AI Brain",
  "version": "1.0.0",
  "description": "Your AI Digital Brain — Chat, Translate, Summarize, and more. Powered by local Ollama LLM.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open AI Brain"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
